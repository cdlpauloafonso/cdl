DATABASE_URL="postgresql://user:password@localhost:5432/cdl_paulo_afonso"
JWT_SECRET="sua-chave-secreta-jwt-mude-em-producao"
PORT=4000
UPLOAD_DIR=./uploads
FRONTEND_URL=http://localhost:3000

# Firebase Admin (inscrições / webhook Asaas)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Asaas — sandbox: https://sandbox.asaas.com → Integrações → API Key
ASAAS_ENABLED=true
ASAAS_ENV=sandbox
ASAAS_API_KEY=
# Token definido no webhook do painel Asaas (header asaas-access-token)
ASAAS_WEBHOOK_TOKEN=

# ---- E-mail (contato + certificados de evento) ----
# Gmail: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  + Senha de app (2FA)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Remetente só para certificados (opcional; usa SMTP_FROM se vazio)
# CERTIFICATE_EMAIL_FROM=certificados@suaorganizacao.com.br

# Certificados por e-mail — manter false até ligar o envio no código
CERTIFICATE_EMAIL_ENABLED=false
# Pausa entre cada e-mail no servidor (ms). Ex.: 3000 = 3s
CERTIFICATE_EMAIL_DELAY_MS=3000
# Máximo por requisição HTTP (o admin fatia lotes maiores sozinho)
CERTIFICATE_EMAIL_MAX_PER_REQUEST=20
# Tamanho do lote que o painel envia por chamada
CERTIFICATE_EMAIL_CLIENT_CHUNK_SIZE=15
