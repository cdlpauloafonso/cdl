DATABASE_URL="postgresql://user:password@localhost:5432/cdl_paulo_afonso"
JWT_SECRET="sua-chave-secreta-jwt-mude-em-producao"
PORT=4000
UPLOAD_DIR=./uploads
FRONTEND_URL=http://localhost:3000

# Token do app WebView (/m/…) — deve coincidir com NEXT_PUBLIC_MOBILE_WEBVIEW_TOKEN no frontend
# MOBILE_WEBVIEW_TOKEN=cdl-mobile-x7k9m356yt1

# Firebase Admin (inscrições / webhook Asaas)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Asaas — sandbox: https://sandbox.asaas.com → Integrações → API Key
ASAAS_ENABLED=true
ASAAS_ENV=sandbox
ASAAS_API_KEY=
# Token definido no webhook do painel Asaas (header asaas-access-token)
ASAAS_WEBHOOK_TOKEN=

# ---- Certificados por e-mail (Resend) ----
# Também pode configurar em Admin → Configurações → APIs (Resend).
RESEND_ENV=sandbox
RESEND_API_KEY=
RESEND_API_KEY_SANDBOX=
RESEND_API_KEY_PRODUCTION=
RESEND_FROM_SANDBOX=onboarding@resend.dev
RESEND_FROM_PRODUCTION=CDL Paulo Afonso <certificados@cdlpauloafonso.com>
# Compatibilidade (chave/remetente únicos — usa o ambiente selecionado em RESEND_ENV):
RESEND_FROM=onboarding@resend.dev
# Ativar envio de certificados por e-mail
CERTIFICATE_EMAIL_ENABLED=false
# Pausa entre cada e-mail no servidor (ms). Ex.: 3000 = 3s
CERTIFICATE_EMAIL_DELAY_MS=3000
# Máximo por requisição HTTP (o admin fatia lotes maiores sozinho)
CERTIFICATE_EMAIL_MAX_PER_REQUEST=20
# Tamanho do lote que o painel envia por chamada
CERTIFICATE_EMAIL_CLIENT_CHUNK_SIZE=15

# ---- E-mail SMTP (contato / formulários; certificados usam Resend acima) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
