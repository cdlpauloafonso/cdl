# ============================================================
# .env_api  —  CDL Paulo Afonso (API em apiassas.cdlpauloafonso.com)
# Copie este arquivo para o servidor como `.env`:
#   cp /www/wwwroot/apiassas.cdlpauloafonso.com/backend/.env_api \
#      /www/wwwroot/apiassas.cdlpauloafonso.com/backend/.env
#   chmod 600 /www/wwwroot/apiassas.cdlpauloafonso.com/backend/.env
# Depois edite e preencha os campos marcados como  <<<< PREENCHER >>>>
# ============================================================

# --- Servidor ----------------------------------------------------------
NODE_ENV=production
PORT=4000
# Caminho onde uploads serão gravados (servido em /uploads)
UPLOAD_DIR=./uploads

# --- CORS --------------------------------------------------------------
# Domínio do site Next.js (sem barra no final)
FRONTEND_URL=https://www.cdlpauloafonso.com

# --- JWT ---------------------------------------------------------------
# Gere um segredo forte no servidor:  openssl rand -hex 48
JWT_SECRET=<<<< PREENCHER: openssl rand -hex 48 >>>>

# --- Firebase Admin ----------------------------------------------------
# OBRIGATÓRIO para login admin (ID token), credenciais Asaas no Firestore e webhook.
# Console Firebase → Configurações do projeto → Contas de serviço → Gerar nova chave.
# Cole o JSON inteiro em UMA ÚNICA LINHA, com aspas simples ao redor.
FIREBASE_SERVICE_ACCOUNT_JSON='<<<< PREENCHER: {"type":"service_account","project_id":"sitecdl",...} >>>>'

# --- Asaas (opcional) --------------------------------------------------
# Você pode deixar vazio e configurar pelo admin: Configurações → APIs (Asaas).
# As chaves salvas no Firestore têm prioridade sobre estas variáveis.
ASAAS_ENABLED=true
ASAAS_ENV=sandbox
ASAAS_API_KEY=
ASAAS_API_KEY_SANDBOX=
ASAAS_API_KEY_PRODUCTION=
# Token que o Asaas envia no header asaas-access-token (configurar igual no painel Asaas)
ASAAS_WEBHOOK_TOKEN=

# --- Banco de dados (placeholder — não usamos Postgres aqui) -----------
# Mantido apenas para o Prisma Client carregar sem erro.
DATABASE_URL="postgresql://disabled:disabled@127.0.0.1:5432/disabled?schema=public"

# --- SMTP / E-mail (opcional) ------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CERTIFICATE_EMAIL_ENABLED=false
CERTIFICATE_EMAIL_DELAY_MS=3000
CERTIFICATE_EMAIL_MAX_PER_REQUEST=20
CERTIFICATE_EMAIL_CLIENT_CHUNK_SIZE=15
