####################################################################
# .env de PRODUÇÃO — copie para `.env` no servidor e preencha.
# Caminho no servidor: /www/wwwroot/apiassas.cdlpauloafonso.com/backend/.env
# Permissão recomendada: chmod 600 .env
####################################################################

# Porta interna do Node (Nginx faz proxy 443 -> 127.0.0.1:4000)
PORT=4000

# Domínio do frontend (libera CORS). Sem barra no final.
FRONTEND_URL=https://www.cdlpauloafonso.com

# Segredo do JWT do admin (rotas legadas). Gere algo longo e aleatório:
#   openssl rand -hex 48
JWT_SECRET=

# Pasta de uploads servida em /uploads (relativa ao backend/).
UPLOAD_DIR=./uploads

####################################################################
# Firebase Admin — necessário para autenticar o admin (ID token),
# salvar credenciais Asaas no Firestore e processar webhooks.
# Cole o JSON inteiro da Service Account em UMA linha.
####################################################################
FIREBASE_SERVICE_ACCOUNT_JSON=

####################################################################
# Asaas — opcional. As chaves podem ser definidas pela tela
# Admin → Configurações → APIs (Asaas), que salva no Firestore e
# tem prioridade sobre estas variáveis.
####################################################################
ASAAS_ENABLED=true
ASAAS_ENV=sandbox
# Compatibilidade com a config antiga (chave única):
ASAAS_API_KEY=
# Chaves separadas por ambiente (preferido):
ASAAS_API_KEY_SANDBOX=
ASAAS_API_KEY_PRODUCTION=
# Token enviado pelo Asaas no header `asaas-access-token` dos webhooks:
ASAAS_WEBHOOK_TOKEN=

####################################################################
# Prisma / Postgres — não é usado pelo fluxo Asaas, mas o cliente
# é importado por rotas legadas. Deixe um valor "placeholder" para o
# build não falhar; nenhuma query será executada nesta API.
# Se um dia for usar Postgres no servidor, ajuste para a string real.
####################################################################
DATABASE_URL="postgresql://disabled:disabled@127.0.0.1:5432/disabled?schema=public"

####################################################################
# SMTP — opcional. Só necessário se este backend for enviar e-mails.
####################################################################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CERTIFICATE_EMAIL_ENABLED=false
CERTIFICATE_EMAIL_DELAY_MS=3000
CERTIFICATE_EMAIL_MAX_PER_REQUEST=20
CERTIFICATE_EMAIL_CLIENT_CHUNK_SIZE=15
