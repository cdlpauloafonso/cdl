rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: admin via custom claim `admin` ou documento em /admins/{uid}
    function isAdmin() {
      return request.auth != null &&
        (request.auth.token.admin == true ||
         request.auth.token.admin == 'true' ||
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // Admins: o próprio usuário pode ler apenas o seu documento (checagem no login)
    match /admins/{adminId} {
      allow get: if request.auth != null && request.auth.uid == adminId;
      allow list, create, update, delete: if false;
    }

    // ---- Eventos / campanhas: inscrição (registrationConfig + documentMode) ----

    function isValidExternalRegistrationConfig(rc) {
      return rc is map
        && rc.type == 'external'
        && rc.url is string
        && rc.url.size() >= 8;
    }

    function isValidFormRegistrationConfig(rc) {
      return rc is map
        && rc.type == 'form'
        && rc.fieldKeys is list
        && rc.fieldKeys.size() >= 1
        && rc.fieldKeys.size() <= 25
        && (
          !('documentMode' in rc)
          || rc.documentMode == 'cnpj_only'
          || rc.documentMode == 'cpf_allowed'
        );
    }

    function isValidRegistrationConfig(rc) {
      return rc == null || isValidExternalRegistrationConfig(rc) || isValidFormRegistrationConfig(rc);
    }

    // Só valida registrationConfig quando o campo entra no write (create ou update parcial).
    function campaignRegistrationConfigValidOnWrite() {
      return !request.resource.data.keys().hasAny(['registrationConfig'])
        || isValidRegistrationConfig(request.resource.data.registrationConfig);
    }

    function numericFieldPositive(v) {
      return (v is int || v is float) && v > 0;
    }

    function numericFieldNonNegative(v) {
      return (v is int || v is float) && v >= 0;
    }

    function campaignInscriptionCount(d) {
      let n = d.get('inscriptionWebCount', 0);
      return numericFieldNonNegative(n) ? n : 0;
    }

    function campaignHasInscriptionLimit(cfg) {
      return cfg is map && numericFieldPositive(cfg.get('inscriptionLimit', 0));
    }

    function isValidVoucherCodeString(code) {
      return code is string
        && code.size() >= 3
        && code.size() <= 40
        && code.matches('^[A-Z0-9_-]+$');
    }

    // Inscrição pública: somente dados do formulário (+ voucher opcional). Pagamento/Asaas só via backend (Admin SDK).
    function inscriptionCreatePayloadValid() {
      let d = request.resource.data;
      let keysOk = d.keys().hasOnly(['createdAt', 'fields'])
        || d.keys().hasOnly(['createdAt', 'fields', 'voucherCode']);
      let voucherOk = !('voucherCode' in d) || isValidVoucherCodeString(d.voucherCode);
      let noPaymentKeys = !d.keys().hasAny([
        'paymentStatus',
        'paymentProvider',
        'paymentAmountApplied',
        'paymentAmountTier',
        'voucherId',
        'asaasPaymentId',
        'asaasInvoiceUrl',
        'asaasCustomerId',
        'asaasLastWebhookEventId',
      ]);
      return keysOk
        && noPaymentKeys
        && voucherOk
        && d.createdAt is string
        && d.createdAt.size() >= 10
        && d.fields is map
        && d.fields.size() >= 1
        && d.fields.size() <= 25;
    }

    function isValidEventVoucherEntry(v) {
      return v is map
        && v.keys().hasAll(['id', 'code', 'discountType', 'discountValue'])
        && v.id is string
        && v.id.size() >= 8
        && v.id.size() <= 64
        && isValidVoucherCodeString(v.code)
        && v.discountType in ['percent', 'fixed']
        && numericFieldPositive(v.discountValue)
        && (v.discountType != 'percent' || v.discountValue <= 100)
        && (!('maxUses' in v) || numericFieldPositive(v.maxUses))
        && (!('usedCount' in v) || numericFieldNonNegative(v.usedCount))
        && (!('active' in v) || v.active is bool)
        && (!('label' in v) || (v.label is string && v.label.size() <= 120))
        && (!('expiresAt' in v) || (v.expiresAt is string && v.expiresAt.matches('^\\d{4}-\\d{2}-\\d{2}$')));
    }

    function isValidEventVouchersList(list) {
      return list is list && list.size() >= 0 && list.size() <= 100;
    }

    function isValidCampaignPaymentConfig(pc) {
      return pc == null
        || (pc is map
          && (!('provider' in pc) || pc.provider in ['manual_pix', 'asaas'])
          && (!('amount' in pc) || numericFieldPositive(pc.amount))
          && (!('amountAssociado' in pc) || numericFieldPositive(pc.amountAssociado))
          && (!('description' in pc) || (pc.description is string && pc.description.size() <= 200))
          && (!('pixImageUrl' in pc) || (pc.pixImageUrl is string && pc.pixImageUrl.size() <= 2048))
          && (!('pixCopyPaste' in pc) || (pc.pixCopyPaste is string && pc.pixCopyPaste.size() <= 4096))
          && (!('pixObservationText' in pc) || (pc.pixObservationText is string && pc.pixObservationText.size() <= 2000)));
    }

    function campaignPaymentAndVouchersValidOnWrite() {
      let d = request.resource.data;
      let payOk = !d.keys().hasAny(['paymentConfig'])
        || isValidCampaignPaymentConfig(d.get('paymentConfig', null));
      let vouchersOk = !d.keys().hasAny(['vouchers'])
        || isValidEventVouchersList(d.get('vouchers', []));
      return payOk && vouchersOk;
    }

    // Uma leitura do evento: publicação, formulário ativo, limite e formato do payload.
    // CPF/CNPJ validados no cliente; regras só exigem mapa fields com 1–25 chaves string.
    function publicInscriptionCreateAllowed(campaignId) {
      let camp = get(/databases/$(database)/documents/campaigns/$(campaignId)).data;
      let cfg = camp.get('registrationConfig', null);
      let n = campaignInscriptionCount(camp);
      let lim = cfg is map ? cfg.get('inscriptionLimit', 0) : 0;
      let withinLimit = !campaignHasInscriptionLimit(cfg) || n < lim;
      return camp.get('published', true) != false
        && camp.get('registrationClosed', false) != true
        && cfg is map
        && cfg.get('type', '') == 'form'
        && withinLimit
        && inscriptionCreatePayloadValid();
    }

    function registrationAllowsCpf(campaignId) {
      let camp = get(/databases/$(database)/documents/campaigns/$(campaignId)).data;
      let cfg = camp.get('registrationConfig', null);
      return cfg is map
        && cfg.get('type', '') == 'form'
        && cfg.get('documentMode', '') == 'cpf_allowed';
    }

    function isValidCpfIndexKey(cpfKey) {
      return cpfKey.matches('^\\d{11}$');
    }

    function inscriptionCpfIndexCreateValid(campaignId, cpfKey) {
      let d = request.resource.data;
      return isValidCpfIndexKey(cpfKey)
        && registrationAllowsCpf(campaignId)
        && !exists(/databases/$(database)/documents/campaigns/$(campaignId)/inscricoesByCpf/$(cpfKey))
        && d.keys().hasOnly(['inscriptionId', 'createdAt'])
        && d.inscriptionId is string
        && d.inscriptionId.size() >= 8
        && d.createdAt is string
        && d.createdAt.size() >= 10;
    }

    // Admin autenticado pode testar inscrição em evento em rascunho (published == false).
    function adminDraftInscriptionCreateAllowed(campaignId) {
      let camp = get(/databases/$(database)/documents/campaigns/$(campaignId)).data;
      let cfg = camp.get('registrationConfig', null);
      return isAdmin()
        && camp.get('published', true) == false
        && camp.get('registrationClosed', false) != true
        && cfg is map
        && cfg.get('type', '') == 'form'
        && inscriptionCreatePayloadValid();
    }

    // Campanhas: leitura pública; escrita só admin, exceto incremento de inscriptionWebCount
    // na inscrição pública quando há limite (transação com criação em inscricoes/).
    // Valores numéricos do SDK podem ser int ou float no rules engine; aceitar ambos.
    function publicInscriptionWebCountIncrement() {
      let cfg = resource.data.get('registrationConfig', null);
      let oldN = campaignInscriptionCount(resource.data);
      let newRaw = request.resource.data.inscriptionWebCount;
      let newN = numericFieldNonNegative(newRaw) ? newRaw : -1;
      return request.auth == null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['inscriptionWebCount'])
        && cfg is map
        && cfg.get('type', '') == 'form'
        && numericFieldPositive(cfg.get('inscriptionLimit', 0))
        && newN == oldN + 1
        && newN <= cfg.get('inscriptionLimit', 0);
    }

    // Link público de credenciamento: token em adminSecrets/credentialing (só admin).
    function credentialingSecretTokenMatches(campaignId, token) {
      let secret = get(/databases/$(database)/documents/campaigns/$(campaignId)/adminSecrets/credentialing);
      return secret != null
        && secret.data.get('accessToken', '') is string
        && token == secret.data.get('accessToken', '');
    }

    function credentialingGateActive(campaignId, sessionId) {
      let gatePath = /databases/$(database)/documents/campaigns/$(campaignId)/credentialingGate/$(sessionId);
      return sessionId is string
        && sessionId.size() >= 8
        && exists(gatePath)
        && request.time < get(gatePath).data.createdAt + duration.value(12, 'h');
    }

    function publicCredentialingInscriptionUpdateAllowed(campaignId) {
      let sid = request.resource.data.get('credentialingSessionId', '');
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      let newAt = request.resource.data.get('credentialedAt', null);
      let atOk = newAt == null || (newAt is string && newAt.size() >= 10 && newAt.size() <= 40);
      return request.auth == null
        && credentialingGateActive(campaignId, sid)
        && keys.hasOnly(['credentialedAt', 'credentialingSessionId'])
        && request.resource.data.credentialingSessionId == sid
        && atOk;
    }

    function isValidCredentialingAccessSecretWrite() {
      return request.resource.data.keys().hasOnly(['accessToken', 'createdAt'])
        && request.resource.data.accessToken is string
        && request.resource.data.accessToken.size() >= 32
        && request.resource.data.accessToken.size() <= 256
        && request.resource.data.createdAt is string
        && request.resource.data.createdAt.size() >= 10;
    }

    match /campaigns/{campaignId} {
      allow get, list: if true;
      allow create: if isAdmin()
        && campaignRegistrationConfigValidOnWrite()
        && campaignPaymentAndVouchersValidOnWrite();
      allow delete: if isAdmin();
      allow update: if (isAdmin()
        && campaignRegistrationConfigValidOnWrite()
        && campaignPaymentAndVouchersValidOnWrite()) || publicInscriptionWebCountIncrement();

      // Inscrições por evento: subcoleção inscricoes (formulário público).
      // Leitura pública: lista de inscritos e tela de credenciamento (somente leitura).
      // Escrita pública: create na inscrição; credentialedAt via sessão do link público (credentialingGate).
      match /inscricoes/{inscriptionId} {
        allow create: if publicInscriptionCreateAllowed(campaignId)
          || adminDraftInscriptionCreateAllowed(campaignId);

        allow get, list: if true;
        allow update: if isAdmin() || publicCredentialingInscriptionUpdateAllowed(campaignId);
        allow delete: if isAdmin();
      }

      // Um CPF por evento quando documentMode == cpf_allowed (índice na transação de inscrição).
      match /inscricoesByCpf/{cpfKey} {
        allow get: if true;
        allow list: if false;
        allow create: if (publicInscriptionCreateAllowed(campaignId)
            || adminDraftInscriptionCreateAllowed(campaignId))
          && inscriptionCpfIndexCreateValid(campaignId, cpfKey);
        allow update, delete: if isAdmin();
      }

      // Sessão efêmera do link público (valida token; documento não é legível).
      match /credentialingGate/{sessionId} {
        allow create: if request.auth == null
          && request.resource.data.keys().hasOnly(['token', 'createdAt'])
          && request.resource.data.token is string
          && request.resource.data.token.size() >= 32
          && request.resource.data.token.size() <= 256
          && request.resource.data.createdAt == request.time
          && credentialingSecretTokenMatches(campaignId, request.resource.data.token);
        allow read, update, delete: if false;
      }

      // Segredos operacionais do evento (não ficam no documento público campaigns/{id}).
      match /adminSecrets/{secretId} {
        allow get, list: if isAdmin();
        allow create, update: if isAdmin()
          && secretId == 'credentialing'
          && isValidCredentialingAccessSecretWrite();
        allow delete: if isAdmin() && secretId == 'credentialing';
      }
    }

    // Incremento público de viewCount em notícia publicada (uma unidade por update).
    function publicNewsViewCountIncrement() {
      let oldV = resource.data.get('viewCount', 0);
      let newV = request.resource.data.viewCount;
      return resource.data.published == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
        && (newV is int || newV is float)
        && (oldV is int || oldV is float)
        && newV == oldV + 1;
    }

    // Notícias: leitura só publicadas (ou admin vê tudo)
    match /news/{newsId} {
      allow get, list: if resource.data.published == true || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || publicNewsViewCountIncrement();
      allow delete: if isAdmin();
    }

    function publicHistoriaViewCountIncrement() {
      let oldV = resource.data.get('viewCount', 0);
      let newV = request.resource.data.viewCount;
      return resource.data.published == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount'])
        && (newV is int || newV is float)
        && (oldV is int || oldV is float)
        && newV == oldV + 1;
    }

    match /historias/{historiaId} {
      allow get, list: if resource.data.published == true || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || publicHistoriaViewCountIncrement();
      allow delete: if isAdmin();
    }

    // Carrossel / hero: leitura pública; escrita admin
    match /carousel/{slideId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Informativos: leitura só ativos (ou admin vê tudo)
    match /informativos/{informativoId} {
      allow get, list: if resource.data.status == 'ativo' || isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /certificadoDigital/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /auditorium/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /about/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Página institucional Nossa Cidade (texto + pontos turísticos)
    match /nossaCidade/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /settings/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /beneficiosAssociados/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Parceiros / convênios da página de benefícios (cards gerenciáveis no admin)
    match /beneficiosParceiros/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /agendamentos/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Contratos: leitura pública; escrita admin
    match /contratos/{documentId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Associados (dados sensíveis): admin total; criação pública restrita via "me associar"
    match /associados/{associadoId} {
      allow get, list, update, delete: if isAdmin();
      allow create: if isAdmin() || (
        request.resource.data.keys().hasOnly([
          'status',
          'origem',
          'nome',
          'empresa',
          'razao_social',
          'cnpj',
          'telefone',
          'telefone_responsavel',
          'data_nascimento_responsavel',
          'email',
          'quantidade_funcionarios',
          'cep',
          'endereco',
          'cidade',
          'estado',
          'plano',
          'codigo_spc',
          'aniversariantes',
          'observacoes',
          'created_at',
          'updated_at'
        ]) &&
        request.resource.data.status == 'em_negociacao' &&
        request.resource.data.origem == 'site' &&
        request.resource.data.nome is string &&
        request.resource.data.nome.size() >= 2 &&
        request.resource.data.empresa is string &&
        request.resource.data.empresa.size() >= 2 &&
        request.resource.data.cnpj is string &&
        request.resource.data.cnpj.size() >= 14 &&
        request.resource.data.telefone is string &&
        request.resource.data.telefone.size() >= 8 &&
        request.resource.data.data_nascimento_responsavel is string &&
        request.resource.data.email is string &&
        request.resource.data.endereco is string &&
        request.resource.data.endereco.size() >= 3 &&
        request.resource.data.cidade is string &&
        request.resource.data.cidade.size() >= 2 &&
        request.resource.data.estado is string &&
        request.resource.data.estado.size() >= 2 &&
        request.resource.data.plano is string &&
        request.resource.data.codigo_spc is string &&
        request.resource.data.aniversariantes is list &&
        request.resource.data.observacoes is string &&
        request.resource.data.created_at is timestamp &&
        request.resource.data.updated_at is timestamp
      );
    }

    // Solicitações públicas de associação: criação sem login; leitura/gestão admin
    match /solicitacoesAssociacao/{docId} {
      allow create: if
        request.resource.data.keys().hasOnly([
          'status',
          'nome',
          'empresa',
          'razao_social',
          'cnpj',
          'telefone',
          'telefone_responsavel',
          'data_nascimento_responsavel',
          'email',
          'quantidade_funcionarios',
          'cep',
          'endereco',
          'cidade',
          'estado',
          'plano',
          'codigo_spc',
          'aniversariantes',
          'observacoes',
          'created_at',
          'updated_at',
          'origem'
        ]) &&
        request.resource.data.status in ['em_negociacao', 'ativo', 'desativado'] &&
        request.resource.data.nome is string &&
        request.resource.data.nome.size() >= 2 &&
        request.resource.data.empresa is string &&
        request.resource.data.empresa.size() >= 2 &&
        request.resource.data.cnpj is string &&
        request.resource.data.cnpj.size() >= 14 &&
        request.resource.data.telefone is string &&
        request.resource.data.telefone.size() >= 8 &&
        request.resource.data.data_nascimento_responsavel is string &&
        request.resource.data.email is string &&
        request.resource.data.endereco is string &&
        request.resource.data.endereco.size() >= 3 &&
        request.resource.data.cidade is string &&
        request.resource.data.cidade.size() >= 2 &&
        request.resource.data.estado is string &&
        request.resource.data.estado.size() >= 2 &&
        request.resource.data.plano is string &&
        request.resource.data.codigo_spc is string &&
        request.resource.data.aniversariantes is list &&
        request.resource.data.observacoes is string &&
        request.resource.data.created_at is timestamp &&
        request.resource.data.updated_at is timestamp &&
        request.resource.data.origem == 'site';

      allow get, list, update, delete: if isAdmin();
    }

    // Índice só com CNPJ (14 dígitos como id): leitura unitária pública para validar inscrição em eventos
    match /associadosCnpjIndex/{cnpjDigits} {
      allow get: if cnpjDigits.matches('^[0-9]{14}$');
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    // Planos de associados (gestão interna): apenas admin
    match /planos/{planoId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    // Integrações (credenciais sensíveis: Asaas etc.).
    // Acesso direto do cliente totalmente bloqueado. Somente backend via Admin SDK.
    match /integrations/{integrationId} {
      allow read, write: if false;
    }

    // Currículos: criação pública sem login; leitura/gestão apenas admin
    match /curriculos/{curriculoId} {
      allow create: if true;

      allow get, list, update, delete: if isAdmin();
    }

    // Vagas: criação pública sem login; leitura pública apenas aprovadas; gestão admin
    match /vagas/{vagaId} {
      allow create: if
        request.resource.data.keys().hasOnly([
          'tituloVaga',
          'empresa',
          'cidade',
          'tipoVaga',
          'tipoContrato',
          'quantidadeVagas',
          'salario',
          'salarioACombinar',
          'descricaoVaga',
          'requisitos',
          'diferenciais',
          'cargaHoraria',
          'prazoCandidatura',
          'recrutadorNome',
          'recrutadorEmail',
          'recrutadorTelefone',
          'status',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.tituloVaga is string &&
        request.resource.data.tituloVaga.size() >= 3 &&
        request.resource.data.empresa is string &&
        request.resource.data.empresa.size() >= 2 &&
        request.resource.data.cidade is string &&
        request.resource.data.cidade.size() >= 2 &&
        request.resource.data.tipoVaga in ['presencial', 'hibrida', 'remota'] &&
        request.resource.data.tipoContrato in ['clt', 'estagio', 'temporario', 'pj', 'jovem-aprendiz', 'outro'] &&
        request.resource.data.quantidadeVagas is int &&
        request.resource.data.quantidadeVagas >= 1 &&
        request.resource.data.salario is string &&
        request.resource.data.salarioACombinar is bool &&
        request.resource.data.descricaoVaga is string &&
        request.resource.data.descricaoVaga.size() >= 10 &&
        request.resource.data.requisitos is string &&
        request.resource.data.requisitos.size() >= 2 &&
        request.resource.data.diferenciais is string &&
        request.resource.data.cargaHoraria is string &&
        request.resource.data.cargaHoraria.size() >= 2 &&
        request.resource.data.prazoCandidatura is string &&
        request.resource.data.recrutadorNome is string &&
        request.resource.data.recrutadorNome.size() >= 2 &&
        request.resource.data.recrutadorEmail is string &&
        request.resource.data.recrutadorEmail.size() >= 5 &&
        request.resource.data.recrutadorTelefone is string &&
        request.resource.data.recrutadorTelefone.size() >= 8 &&
        request.resource.data.status == 'pendente' &&
        request.resource.data.createdAt is string &&
        request.resource.data.updatedAt is string;

      allow get, list: if isAdmin() || resource.data.status == 'aprovada';
      allow update, delete: if isAdmin();
    }

    // Negar o restante
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
